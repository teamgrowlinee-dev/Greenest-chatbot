# Google Apps Script backend URL (copy from code.gs deployment)
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Security token (must match GREENEST_SITE_TOKEN in Apps Script properties)
SITE_TOKEN=greenest_live_REPLACE_ME

# Set by Render automatically — do not change
# RENDER_EXTERNAL_URL=https://your-service.onrender.com
